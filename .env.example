# 环境变量示例文件 — 复制为 .env 并填入真实值

# ===== 数据库配置 =====
DATABASE_URL=postgresql://ai_skill:ai_skill_password@localhost:5432/ai_skill_web

# ===== Docker Compose 数据库配置 =====
POSTGRES_USER=ai_skill
POSTGRES_PASSWORD=ai_skill_password
POSTGRES_DB=ai_skill_web

# ===== AI API Keys =====
# Anthropic (Claude)
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# OpenAI (GPT)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# ===== 应用配置 =====
# 认证密钥（生产环境必须修改为随机字符串）
NEXTAUTH_SECRET=your-secret-key-change-in-production

# 应用访问地址（生产环境修改为实际域名）
NEXTAUTH_URL=http://localhost:3000

# Docker Compose 端口配置
APP_PORT=3000
