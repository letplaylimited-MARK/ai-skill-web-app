.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/

# ====================
# 版本控制
# ====================
.git
.gitignore
.gitattributes

# ====================
# 依赖（镜像内会重新安装）
# ====================
node_modules/
.pnpm-store/

# ====================
# 构建产物与缓存（避免污染 Docker 层）
# ====================
.next/
out/
dist/
build/
.turbo/
.cache/

# ====================
# 测试与覆盖率
# ====================
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__/
__mocks__/
jest.config.*
vitest.config.*

# ====================
# 日志与临时文件
# ====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
tmp/
temp/

# ====================
# 开发工具配置
# ====================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ====================
# CI/CD 与文档
# ====================
.github/
docs/
*.md
!README.md

# ====================
